rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOrgMember(orgId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/orgMembers/$(orgId + '_' + request.auth.uid));
    }

    function getOrgRole(orgId) {
      return get(/databases/$(database)/documents/orgMembers/$(orgId + '_' + request.auth.uid)).data.role;
    }

    function isOrgAdmin(orgId) {
      return isOrgMember(orgId) && getOrgRole(orgId) in ['owner', 'admin'];
    }

    function isOrgOwner(orgId) {
      return isOrgMember(orgId) && getOrgRole(orgId) == 'owner';
    }

    // Profiles - publicly readable, admin writable
    match /profiles/{profileId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Competency categories - publicly readable, admin writable
    match /competencyCategories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Questions - publicly readable (for evaluations), admin writable
    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Evaluations - candidates can create and update their own
    match /evaluations/{evaluationId} {
      // Anyone can create (for anonymous evaluations)
      allow create: if true;
      // Candidates can read/update their own evaluation
      allow read: if true;
      allow update: if resource.data.candidateId == request.resource.data.candidateId;
      // Admins can do anything
      allow delete: if isAdmin();
    }

    // Results - candidates can read their own, admins can read/write all
    match /results/{resultId} {
      allow read: if true;
      allow write: if isAdmin() || request.auth != null;
    }

    // Archetype profiles - publicly readable, admin writable
    match /archetypeProfiles/{archetypeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Resources - publicly readable, admin writable
    match /resources/{resourceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings - admin only
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Admin users
    match /admins/{adminId} {
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      allow write: if isAdmin();
    }

    // Evaluation links - publicly readable, admin writable
    match /evaluationLinks/{linkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Phase 4: Test configs - publicly readable, admin writable
    match /cognitiveTests/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /personalityTests/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /aptitudeTests/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /discTests/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /testSessions/{sessionId} {
      allow create: if true;
      allow read: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }
    match /combinedResults/{resultId} {
      allow read: if true;
      allow write: if isAdmin() || request.auth != null;
    }

    // Phase 5: Technical tests & job profiles
    match /technicalTests/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /jobProfiles/{profileId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Phase 7: Post-hire evaluations
    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /probationEvaluations/{evalId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /reviewCampaigns/{campaignId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /reviewAssignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    match /reviewSummaries/{summaryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /climateSurveys/{surveyId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /climateResponses/{responseId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
    match /climateSurveyResults/{resultId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Organizations
    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOrgAdmin(orgId) || isAdmin();
      allow delete: if isOrgOwner(orgId) || isAdmin();
    }

    // Organization Members
    match /orgMembers/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        isAdmin() ||
        (resource == null && isOrgAdmin(request.resource.data.orgId))
      );
      allow update: if isOrgAdmin(resource.data.orgId) || isAdmin();
      allow delete: if isOrgAdmin(resource.data.orgId) || resource.data.userId == request.auth.uid || isAdmin();
    }

    // Organization Invites
    match /orgInvites/{inviteId} {
      allow read: if isAuthenticated();
      allow create: if isOrgAdmin(request.resource.data.orgId) || isAdmin();
      allow update: if isAuthenticated() && (
        resource.data.email == request.auth.token.email ||
        isOrgAdmin(resource.data.orgId) ||
        isAdmin()
      );
      allow delete: if isOrgAdmin(resource.data.orgId) || isAdmin();
    }

    // User Profiles
    match /userProfiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
